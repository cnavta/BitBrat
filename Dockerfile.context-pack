FROM node:24-slim AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

FROM node:24-slim
WORKDIR /app
COPY package*.json ./
RUN npm ci --production
COPY --from=builder /app/dist ./dist
COPY architecture.yaml ./

ENV NODE_ENV=production
ENV SERVICE_NAME=context-pack

CMD ["node", "dist/apps/context-pack-service.js"]
