rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Emulator/local development rules — permissive for rapid iteration.
    // DO NOT USE IN PRODUCTION.
    match /{document=**} {
      allow read, write, delete: if true;
    }

    // Production guidance (non-enforced here):
    // In production, restrict client reads to the /personalities collection and disallow writes.
    // Note: Admin SDK (used by llm-bot) bypasses rules and should be run under a least-privilege service account
    // with read-only access to /personalities.
    //
    // match /personalities/{doc} {
    //   allow read: if request.auth != null;
    //   allow write: if false;
    // }

    // Users collection guidance:
    // Application services (server-side/Admin SDK) should own writes to /users only.
    // End-user clients should NOT have direct write access to /users.
    // Example (hardened) production stance:
    // match /users/{doc} {
    //   allow read: if false;            // or restrict to privileged viewer roles
    //   allow write: if false;           // all writes via Admin SDK/service account
    // }

    // Sprint 254: Agent State Memory
    match /state/{doc} {
      allow read: if true; // Ingress-Egress, LLM Bot, and State Engine need access
      allow write: if false; // All writes MUST go through State Engine (Admin SDK)
    }

    match /mutation_log/{doc} {
      allow read: if true; // For auditability
      allow write: if false; // All writes MUST go through State Engine (Admin SDK)
    }

    // Sprint 332: Reflex Bit
    // Reflexes are pattern-action rules for deterministic event handling
    match /reflexes/{doc} {
      allow read: if true; // Reflex service needs read access via Admin SDK
      allow write: if false; // All writes MUST go through Reflex MCP tools (Admin SDK)
      // Production: In production, restrict client read access or use Admin SDK exclusively
      // Production: MCP tools use Admin SDK with service account credentials
    }
  }
}
